# .env.example — canonical env-var template for this Eve agent project.
#
# Copy this file to `.env.local` (gitignored) and fill in your values:
#   cp .env.example .env.local     # Unix
#   copy .env.example .env.local   # Windows
#
# `npm install` runs `scripts/bootstrap-env.mjs` as a postinstall step,
# which does the copy automatically when `.env.local` is missing.
# Never commit `.env.local` or any real secret value.

# ---------------------------------------------------------------------------
# Default model provider — MiniMax-M3
# ---------------------------------------------------------------------------
# Get a key from https://MiniMax — keep this OUT of version control.
MINIMAX_API_KEY=

# ---------------------------------------------------------------------------
# Optional: switch to a local or Ollama Cloud model instead of MiniMax
# ---------------------------------------------------------------------------
# Set USE_OLLAMA=1 to boot agent/agent.ts on the OpenAI-compatible Ollama
# endpoint. The context window adjusts automatically (131_072 for Ollama,
# 1_000_000 for MiniMax).
USE_OLLAMA=
OLLAMA_BASE_URL=http://localhost:11434/v1
# `ollama` is the placeholder for local Ollama. Ollama Cloud
# (https://ollama.com/v1) requires your account key here instead.
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Route-auth API keys for agent/channels/eve.ts
# ---------------------------------------------------------------------------
# Format: client-name:key,client-name:key (comma-separated).
# Generate with: node scripts/generate-api-key.mjs <client-name>
# Clients send the key via the X-Api-Key header on every /eve/v1/session* request.
EVE_API_KEYS=

# ---------------------------------------------------------------------------
# Optional: allow the eve dev TUI to connect via loopback.
# ---------------------------------------------------------------------------
# NEVER set this in production. `localDev()` accepts any request from a
# loopback address and skips API-key checks, so a co-resident attacker
# (malicious dep, RCE in another service, DNS rebinding) could otherwise
# bypass auth via SSRF.
EVE_ENABLE_LOCAL_DEV=